{
  "name": "@formitiva/react",
  "version": "2.1.7",
  "description": "Formitiva React adapter — components, hooks and registries",
  "keywords": ["formitiva", "form", "form-builder", "form-validation", "dynamic-form", "react", "react-form", "hooks", "typescript"],
  "repository": {
    "type": "git",
    "url": "https://github.com/formitiva/formitiva-monorepo.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/formitiva/formitiva-monorepo/issues"
  },
  "homepage": "https://github.com/formitiva/formitiva-monorepo/tree/main/packages/react#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "lint": "tsc -p tsconfig.typecheck.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@formitiva/core": "workspace:^",
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@formitiva/core": "workspace:^2.1.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "react": "^18",
    "react-dom": "^18",
    "rimraf": "^5.0.0",
    "typescript": "~5.4.0",
    "vitest": "^4.1.0"
  }
}
