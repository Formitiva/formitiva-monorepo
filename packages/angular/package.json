{
  "name": "@formitiva/angular",
  "version": "2.0.0",
  "description": "Formitiva Angular adapter — module, components and services",
  "keywords": ["formitiva", "form", "form-builder", "form-validation", "dynamic-form", "angular", "angular-module", "typescript"],
  "repository": {
    "type": "git",
    "url": "https://github.com/formitiva/formitiva-monorepo.git",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/formitiva/formitiva-monorepo/issues"
  },
  "homepage": "https://github.com/formitiva/formitiva-monorepo/tree/main/packages/angular#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@formitiva/core": "workspace:*",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@angular/core": ">=18",
    "@angular/common": ">=18",
    "@angular/forms": ">=18",
    "rxjs": ">=7"
  },
  "devDependencies": {
    "@angular/core": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "rxjs": "^7.0.0",
    "typescript": "~5.6.3",
    "rimraf": "^5.0.0",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
