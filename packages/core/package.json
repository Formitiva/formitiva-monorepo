{
  "name": "@formitiva/core",
  "version": "1.0.0",
  "description": "Formitiva shared core — types, validation, registries and utilities (framework-agnostic)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": {
      "import": "./dist/styles/cssClasses.js",
      "types": "./dist/styles/cssClasses.d.ts"
    },
    "./styles/formitiva.css": "./src/styles/formitiva.css",
    "./themes/*": "./src/themes/*"
  },
  "files": ["dist", "src/styles/formitiva.css", "src/themes"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "~5.4.0",
    "rimraf": "^5.0.0",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
