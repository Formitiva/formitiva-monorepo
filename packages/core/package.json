{
  "name": "@formitiva/core",
  "version": "2.1.4",
  "description": "Formitiva shared core — types, validation, registries and utilities (framework-agnostic)",
  "keywords": ["formitiva", "form", "form-builder", "form-validation", "schema", "dynamic-form", "typescript", "framework-agnostic"],
  "repository": {
    "type": "git",
    "url": "https://github.com/formitiva/formitiva-monorepo.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/formitiva/formitiva-monorepo/issues"
  },
  "homepage": "https://github.com/formitiva/formitiva-monorepo/tree/main/packages/core#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": {
      "import": "./dist/styles/cssClasses.js",
      "types": "./dist/styles/cssClasses.d.ts"
    },
    "./styles/formitiva.css": "./src/styles/formitiva.css",
    "./themes/*": "./src/themes/*"
  },
  "files": ["dist", "src/styles/formitiva.css", "src/themes"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "~5.4.0",
    "rimraf": "^5.0.0",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
